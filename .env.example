ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
NOTION_API_KEY=your_notion_api_key_here
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id_here

# Market Research APIs (all optional — system degrades gracefully if missing)
# Brave Search — real competitor/product search. Free: 2K queries/mo
# Get key at: https://brave.com/search/api/
BRAVE_API_KEY=
# Firecrawl — full page content extraction. Free: 500 pages/mo
# Get key at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=
# Max pages to scrape per run (default: 3, respects monthly 500 limit)
FIRECRAWL_MAX_PER_RUN=3

# Reddit API — OAuth2 for authenticated access (optional, public endpoint works without it)
# Higher rate limits + stability. Create app: https://www.reddit.com/prefs/apps → "script"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# NewsAPI — latest industry news. Free: 100 requests/day
# Get key at: https://newsapi.org/register
NEWSAPI_KEY=

# Gumroad API token for publishing products
GUMROAD_ACCESS_TOKEN=
# Gumroad username (subdomain) — optional, auto-detected from API if unset
GUMROAD_USERNAME=

# Landing page generation (Google Stitch + Vercel)
GEMINI_API_KEY=

# Imagen free image generation endpoint (Cloudflare Worker)
IMAGEN_API_KEY=your_imagen_api_key_here
IMAGEN_API_URL=https://your-imagen-worker-url.workers.dev

# Google Stitch — screen download/creation via MCP API
STITCH_API_KEY=
# Comma-separated project IDs to download screens from (leave empty for all accessible projects)
STITCH_PROJECT_IDS=

VERCEL_TOKEN=

# Social media promotion (Facebook Graph API + Pinterest)
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_USER_ID=
THREADS_USER_ID=
PINTEREST_TOKEN=
PINTEREST_BOARD_ID=
