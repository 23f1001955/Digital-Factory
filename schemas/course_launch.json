{
  "product_type": "course_launch",
  "display_name": "Course Launch Kit",
  "notion_sync": true,
  "components": [
    {
      "id": "market_research",
      "agent": "market_agent",
      "output": "data/market_research.json",
      "depends_on": []
    },
    {
      "id": "images",
      "agent": "image_agent",
      "output": "data/images_generated.json",
      "depends_on": ["market_research"]
    },
    {
      "id": "course_outline",
      "agent": "content_agent",
      "output": "content/course_outline.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "lessons",
      "agent": "content_agent",
      "output": "content/lessons.md",
      "depends_on": [
        "course_outline"
      ]
    },
    {
      "id": "marketing_copy",
      "agent": "content_agent",
      "output": "content/marketing_copy.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "timeline",
      "agent": "content_agent",
      "output": "content/timeline.md",
      "depends_on": [
        "course_outline",
        "marketing_copy"
      ]
    },
    {
      "id": "outline_pdf",
      "agent": "render_agent",
      "output": "presentation/outline.pdf",
      "depends_on": [
        "course_outline",
        "images"
      ],
      "uses_renderer": true,
      "template": "shared/basic_doc.html.j2"
    },
    {
      "id": "launch_pdf",
      "agent": "render_agent",
      "output": "presentation/launch_plan.pdf",
      "depends_on": [
        "timeline",
        "images"
      ],
      "uses_renderer": true,
      "template": "shared/basic_doc.html.j2"
    },
    {
      "id": "notion_tree",
      "agent": "notion_agent",
      "output": "notion_sync.json",
      "depends_on": [
        "course_outline",
        "lessons",
        "marketing_copy",
        "timeline"
      ]
    },
    {
      "id": "package",
      "agent": "packaging_agent",
      "output": "{slug}.zip",
      "depends_on": [
        "outline_pdf",
        "launch_pdf",
        "notion_tree"
      ]
    },
    {
      "id": "gumroad_research",
      "agent": "gumroad_agent",
      "output": "gumroad/research.json",
      "depends_on": [
        "outline_pdf",
        "launch_pdf"
      ]
    },
    {
      "id": "gumroad_publish",
      "agent": "gumroad_agent",
      "output": "gumroad/published.json",
      "depends_on": [
        "gumroad_research"
      ]
    },
    {
      "id": "landing_page",
      "agent": "landing_agent",
      "output": "landing/deployed.json",
      "depends_on": ["gumroad_publish"]
    },
    {
      "id": "social_promotion",
      "agent": "social_agent",
      "output": "landing/social_results.json",
      "depends_on": ["landing_page"]
    }
  ],
  "notion_structure": {
    "pages": [
      {
        "name": "Course Outline",
        "source": "course_outline"
      },
      {
        "name": "Lessons",
        "source": "lessons"
      },
      {
        "name": "Marketing Copy",
        "source": "marketing_copy"
      },
      {
        "name": "Launch Timeline",
        "source": "timeline"
      }
    ]
  }
}