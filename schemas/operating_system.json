{
  "product_type": "operating_system",
  "display_name": "Operating System",
  "notion_sync": true,
  "components": [
    {
      "id": "market_research",
      "agent": "market_agent",
      "output": "data/market_research.json",
      "depends_on": []
    },
    {
      "id": "images",
      "agent": "image_agent",
      "output": "data/images_generated.json",
      "depends_on": ["market_research"]
    },
    {
      "id": "guide",
      "agent": "content_agent",
      "output": "content/guide.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "sops",
      "agent": "content_agent",
      "output": "content/sops.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "templates",
      "agent": "content_agent",
      "output": "content/templates.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "prompts",
      "agent": "content_agent",
      "output": "content/prompts.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "stitch_download",
      "agent": "stitch_agent",
      "output": "stitch/screens",
      "depends_on": [
        "guide",
        "sops",
        "templates"
      ]
    },
    {
      "id": "guide_pdf",
      "agent": "render_agent",
      "output": "presentation/guide.pdf",
      "depends_on": [
        "guide",
        "images"
      ],
      "uses_renderer": true,
      "template": "shared/basic_doc.html.j2"
    },
    {
      "id": "sops_pdf",
      "agent": "render_agent",
      "output": "presentation/sops.pdf",
      "depends_on": [
        "sops",
        "images"
      ],
      "uses_renderer": true,
      "template": "shared/basic_doc.html.j2"
    },
    {
      "id": "notion_schema",
      "agent": "notion_schema_agent",
      "output": "data/notion_schema.json",
      "depends_on": [
        "guide",
        "sops",
        "templates",
        "prompts"
      ]
    },
    {
      "id": "notion_tree",
      "agent": "notion_agent",
      "output": "notion_sync.json",
      "depends_on": [
        "notion_schema",
        "guide",
        "sops",
        "templates",
        "prompts"
      ]
    },
    {
      "id": "package",
      "agent": "packaging_agent",
      "output": "{slug}.zip",
      "depends_on": [
        "guide_pdf",
        "sops_pdf",
        "notion_tree"
      ]
    },
    {
      "id": "stitch_assets",
      "agent": "stitch_agent",
      "output": "stitch",
      "depends_on": ["market_research"]
    },
    {
      "id": "gumroad_research",
      "agent": "gumroad_agent",
      "output": "gumroad/research.json",
      "depends_on": [
        "guide_pdf",
        "sops_pdf"
      ]
    },
    {
      "id": "gumroad_publish",
      "agent": "gumroad_agent",
      "output": "gumroad/published.json",
      "depends_on": [
        "gumroad_research",
        "guide_pdf",
        "sops_pdf"
      ]
    },
    {
      "id": "landing_page",
      "agent": "landing_agent",
      "output": "landing/deployed.json",
      "depends_on": ["gumroad_publish", "stitch_assets"]
    },
    {
      "id": "social_promotion",
      "agent": "social_agent",
      "output": "landing/social_results.json",
      "depends_on": ["landing_page"]
    }
  ],
  "notion_structure": {
    "pages": [
      {
        "name": "Guide",
        "source": "guide"
      },
      {
        "name": "SOPs",
        "source": "sops"
      },
      {
        "name": "Templates",
        "source": "templates"
      },
      {
        "name": "Prompts",
        "source": "prompts"
      }
    ]
  }
}