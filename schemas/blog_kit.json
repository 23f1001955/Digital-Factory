{
  "product_type": "blog_kit",
  "display_name": "Blog Kit",
  "notion_sync": false,
  "components": [
    {
      "id": "market_research",
      "agent": "market_agent",
      "output": "data/market_research.json",
      "depends_on": []
    },
    {
      "id": "images",
      "agent": "image_agent",
      "output": "data/images_generated.json",
      "depends_on": ["market_research"]
    },
    {
      "id": "database",
      "agent": "research_agent",
      "output": "data/database.json",
      "depends_on": ["market_research"]
    },
    {
      "id": "sources",
      "agent": "research_agent",
      "output": "content/sources.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "post_draft",
      "agent": "content_agent",
      "output": "content/post_draft.md",
      "depends_on": [
        "market_research",
        "database",
        "sources"
      ]
    },
    {
      "id": "seo_metadata",
      "agent": "content_agent",
      "output": "content/seo_metadata.md",
      "depends_on": [
        "post_draft"
      ]
    },
    {
      "id": "stitch_download",
      "agent": "stitch_agent",
      "output": "stitch/screens",
      "depends_on": [
        "post_draft",
        "seo_metadata"
      ]
    },
    {
      "id": "compilation_pdf",
      "agent": "render_agent",
      "output": "presentation/compilation.pdf",
      "depends_on": [
        "post_draft",
        "images"
      ],
      "uses_renderer": true,
      "template": "shared/basic_doc.html.j2"
    },
    {
      "id": "package",
      "agent": "packaging_agent",
      "output": "{slug}.zip",
      "depends_on": [
        "compilation_pdf"
      ]
    },
    {
      "id": "stitch_assets",
      "agent": "stitch_agent",
      "output": "stitch",
      "depends_on": ["market_research"]
    },
    {
      "id": "gumroad_research",
      "agent": "gumroad_agent",
      "output": "gumroad/research.json",
      "depends_on": [
        "compilation_pdf"
      ]
    },
    {
      "id": "gumroad_publish",
      "agent": "gumroad_agent",
      "output": "gumroad/published.json",
      "depends_on": [
        "gumroad_research",
        "compilation_pdf"
      ]
    },
    {
      "id": "landing_page",
      "agent": "landing_agent",
      "output": "landing/deployed.json",
      "depends_on": ["gumroad_publish", "stitch_assets"]
    },
    {
      "id": "social_promotion",
      "agent": "social_agent",
      "output": "landing/social_results.json",
      "depends_on": ["landing_page"]
    }
  ]
}