{
  "product_type": "saas_docs",
  "display_name": "SaaS Documentation",
  "notion_sync": false,
  "components": [
    {
      "id": "market_research",
      "agent": "market_agent",
      "output": "data/market_research.json",
      "depends_on": []
    },
    {
      "id": "images",
      "agent": "image_agent",
      "output": "data/images_generated.json",
      "depends_on": ["market_research"]
    },
    {
      "id": "api_reference",
      "agent": "content_agent",
      "output": "content/api_reference.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "user_guide",
      "agent": "content_agent",
      "output": "content/user_guide.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "changelog",
      "agent": "content_agent",
      "output": "content/changelog.md",
      "depends_on": ["market_research"]
    },
    {
      "id": "stitch_download",
      "agent": "stitch_agent",
      "output": "stitch/screens",
      "depends_on": [
        "api_reference",
        "user_guide",
        "changelog"
      ]
    },
    {
      "id": "docs_pdf",
      "agent": "render_agent",
      "output": "presentation/docs.pdf",
      "depends_on": [
        "api_reference",
        "user_guide",
        "changelog",
        "images"
      ],
      "uses_renderer": true,
      "template": "shared/basic_doc.html.j2"
    },
    {
      "id": "package",
      "agent": "packaging_agent",
      "output": "{slug}.zip",
      "depends_on": [
        "docs_pdf"
      ]
    },
    {
      "id": "stitch_assets",
      "agent": "stitch_agent",
      "output": "stitch",
      "depends_on": ["market_research"]
    },
    {
      "id": "gumroad_research",
      "agent": "gumroad_agent",
      "output": "gumroad/research.json",
      "depends_on": [
        "docs_pdf"
      ]
    },
    {
      "id": "gumroad_publish",
      "agent": "gumroad_agent",
      "output": "gumroad/published.json",
      "depends_on": [
        "gumroad_research",
        "docs_pdf"
      ]
    },
    {
      "id": "landing_page",
      "agent": "landing_agent",
      "output": "landing/deployed.json",
      "depends_on": ["gumroad_publish", "stitch_assets"]
    },
    {
      "id": "social_promotion",
      "agent": "social_agent",
      "output": "landing/social_results.json",
      "depends_on": ["landing_page"]
    }
  ]
}